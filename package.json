{
  "name": "kausal-paths-ui",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:webpack": "next dev --webpack",
    "dev:inspect": "NODE_OPTIONS='--inspect' next dev",
    "build": "next build",
    "build:webpack": "next build --webpack",
    "start": "next start",
    "graphql-codegen": "graphql-codegen --config codegen.ts && prettier --write ./src/common/__generated__/graphql.ts ./e2e-tests/__generated__/graphql.ts",
    "prettier:fix": "prettier --write --cache ./",
    "prettier:check": "prettier --check --cache ./",
    "typecheck": "tsc -b",
    "typecheck:baseline": "tsc -b | tsc-baseline -p tsc-baseline.json check",
    "typecheck:baseline:ci": "tsc -b | tsc-baseline -p tsc-baseline.json check --error-format gitlab 2>&1 | node kausal_common/scripts/gitlab-to-rdjsonl.js",
    "typecheck:baseline:update": "tsc -b | tsc-baseline -p tsc-baseline.json save",
    "lint": "eslint --cache",
    "lint:baseline": "eslint --cache --suppressions-location eslint-baseline.json",
    "lint:baseline:ci": "eslint --cache --suppressions-location eslint-baseline.json -f rdjson",
    "lint:baseline:update": "eslint --cache --suppressions-location eslint-baseline.json --prune-suppressions",
    "lint:baseline:suppress": "eslint --suppress-all --suppressions-location eslint-baseline.json",
    "lint:summary": "eslint --cache -f summary",
    "lint:nibble": "dlx eslint-nibble --cache ."
  },
